    },
    {
      "command": "oa_sys_shell",
      "info": "Regenerating Initramfs for live system",
      "run_command": "update-initramfs -u -k all || update-initramfs -c -k all",
      "chroot": true
    },
    {
      "command": "oa_remaster_livestruct"
    },
    {
      "command": "oa_remaster_isolinux",
      "boot_params": "boot=live components quiet splash"
    },
    {
      "command": "oa_remaster_uefi",
      "boot_params": "boot=live components quiet splash"
    },
    {
      "command": "oa_remaster_squash",
