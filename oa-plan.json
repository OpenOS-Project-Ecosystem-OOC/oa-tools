    {
      "command": "oa_sys_shell",
      "info": "Applying passwordless sudo configuration",
      "run_command": "mkdir -p /etc/sudoers.d \u0026\u0026 echo '%sudo ALL=(ALL) NOPASSWD: ALL' \u003e /etc/sudoers.d/00-oa-live \u0026\u0026 chmod 0440 /etc/sudoers.d/00-oa-live",
